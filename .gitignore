pfsense-config.xml

# Generated, sanitized ruleset (rules + interface map). Reveals network
# topology even though it has no secrets — keep it local. Produced by
# `python -m src.tools.extract_pfsense pfsense-config.xml -o rules.yaml`.
# The synthetic samples/example_rules.yaml IS committed for tests/demos.
/rules.yaml
