# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# macOS
.DS_Store

# Runtime data / databases
/data/
*.db

# Real network captures — keep these local, do not publish.
# Synthetic samples (example_config.xml) are committed for tests/demos.
samples/filter.log

# Real pfSense config backup — contains secrets (password hashes, VPN keys).
# Never commit. Only needed transiently to extract rules.yaml.
pfsense-config.xml

# Local working config — copied from the committed *.example.yaml templates.
# settings.yaml may hold deployment-specific values; rules.yaml reveals network
# topology. Both stay local; the templates document the format.
/settings.yaml
/rules.yaml
